#!/usr/bin/env bash
set -euo pipefail

PW_BIN="${PW_BIN:-playwright-cli}"
PW_HOME="${PW_HOME:-$HOME/.dalek/playwright}"
PW_SESSION="${PW_SESSION:-shared}"
PW_SKILL_DIR="${PW_SKILL_DIR:-$HOME/.dalek/playwright/skill}"
PW_CALLER_CWD="${PWD}"

_pw_usage() {
  cat <<'EOF'
pw: shared playwright-cli wrapper

Usage:
  pw setup             First-time setup: install playwright-cli + generate config
  pw open [url]        Open browser once; when already running, create a new tab
  pw close [index]     Close current tab (or the specified tab index)
  pw stop              Stop browser session
  pw status            Show browser session status
  pw init-skill        Install pw skill into current project's .claude/skills/
  pw <command> [...]   Forward any other command to playwright-cli

Environment:
  PW_HOME              Shared workspace path (default: ~/.dalek/playwright)
  PW_SESSION           Shared session name (default: shared)
  PW_SKILL_DIR         Skill source directory (default: ~/.dalek/playwright/skill)
  PW_BIN               playwright-cli binary (default: playwright-cli)
EOF
}

_pw_require_cli() {
  if ! command -v "$PW_BIN" >/dev/null 2>&1; then
    echo "[pw] command not found: $PW_BIN" >&2
    exit 127
  fi
}

_pw_find_template() {
  # skill dir inside project (git-tracked)
  local project_skill="${PW_CALLER_CWD}/.claude/skills/playwright-cli/templates/cli.config.template.json"
  if [[ -f "$project_skill" ]]; then
    printf '%s\n' "$project_skill"
    return 0
  fi
  # global skill dir
  local global_skill="$PW_SKILL_DIR/templates/cli.config.template.json"
  if [[ -f "$global_skill" ]]; then
    printf '%s\n' "$global_skill"
    return 0
  fi
  return 1
}

_pw_find_repo_root() {
  local dir="$PW_CALLER_CWD"
  while true; do
    if [[ -d "$dir/.git" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    if [[ "$dir" == "/" ]]; then
      break
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

_pw_setup() {
  echo "[pw] === playwright-cli setup ==="
  echo ""

  # Step 1: install playwright-cli
  if command -v "$PW_BIN" >/dev/null 2>&1; then
    local ver=""
    ver="$("$PW_BIN" --version 2>/dev/null || echo "unknown")"
    echo "[pw] playwright-cli found: $ver"
  else
    echo "[pw] playwright-cli not found."
    echo "[pw] install with:  npm install -g @playwright/cli@latest"
    printf "[pw] install now? [y/N] "
    read -r ans
    if [[ "$ans" == "y" || "$ans" == "Y" ]]; then
      npm install -g @playwright/cli@latest
      echo "[pw] playwright-cli installed."
    else
      echo "[pw] skipped. install manually before using pw."
    fi
  fi
  echo ""

  # Step 2: install pw to PATH
  local pw_script=""
  pw_script="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  local pw_link="$HOME/.local/bin/pw"
  mkdir -p "$HOME/.local/bin"
  ln -sf "$pw_script" "$pw_link"
  echo "[pw] linked: $pw_link -> $pw_script"
  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$HOME/.local/bin"; then
    echo "[pw] warning: ~/.local/bin is not in PATH. add to your shell profile:"
    echo "[pw]   export PATH=\"\$HOME/.local/bin:\$PATH\""
  fi
  echo ""

  # Step 3: generate ~/.playwright/ from templates
  local config_dir="$HOME/.playwright"
  local config_path="$config_dir/cli.config.json"

  if [[ -f "$config_path" ]]; then
    printf "[pw] config already exists: %s\n" "$config_path"
    printf "[pw] overwrite? [y/N] "
    read -r ans
    if [[ "$ans" != "y" && "$ans" != "Y" ]]; then
      echo "[pw] kept existing config."
    else
      _pw_render_config "$config_dir"
    fi
  else
    _pw_render_config "$config_dir"
  fi
  echo ""

  # Step 4: seed global skill cache + install to project
  local repo_root=""
  if repo_root="$(_pw_find_repo_root)"; then
    local project_skill="$repo_root/.claude/skills/playwright-cli"
    # seed global from project (if project has skill)
    if [[ -d "$project_skill" ]]; then
      mkdir -p "$PW_SKILL_DIR"
      cp -R "$project_skill"/* "$PW_SKILL_DIR"/
      echo "[pw] global skill cache seeded from project."
    # install to project from global (if project missing)
    elif [[ -d "$PW_SKILL_DIR" ]]; then
      mkdir -p "$project_skill"
      cp -R "$PW_SKILL_DIR"/* "$project_skill"/
      echo "[pw] skill installed to $project_skill/"
    else
      echo "[pw] warning: no skill source found, skip skill install."
    fi
  fi
  echo ""
  echo "[pw] setup complete. run 'pw open' to start."
}

_pw_render_config() {
  local config_dir="$1"

  local template=""
  if ! template="$(_pw_find_template)"; then
    echo "[pw] error: config template not found." >&2
    echo "[pw] expected at: .claude/skills/playwright-cli/templates/cli.config.template.json" >&2
    return 1
  fi
  local template_dir=""
  template_dir="$(dirname "$template")"

  mkdir -p "$config_dir"

  # Process all files in templates/
  local f=""
  while IFS= read -r -d '' f; do
    local name=""
    name="$(basename "$f")"
    if [[ "$name" == *.template.json ]]; then
      # Render template: replace __HOME__, strip .template suffix
      local target_name="${name%.template.json}.json"
      sed "s|__HOME__|$HOME|g" "$f" > "$config_dir/$target_name"
      echo "[pw] rendered: $config_dir/$target_name"
    else
      # Copy companion files as-is
      cp "$f" "$config_dir/$name"
      echo "[pw] copied: $config_dir/$name"
    fi
  done < <(find "$template_dir" -mindepth 1 -maxdepth 1 -type f -print0)
}

_pw_find_config() {
  if [[ -n "${PW_CONFIG:-}" && -f "${PW_CONFIG}" ]]; then
    printf '%s\n' "${PW_CONFIG}"
    return 0
  fi

  if [[ -n "${DALEK_REPO_ROOT:-}" && -f "${DALEK_REPO_ROOT}/.playwright/cli.config.json" ]]; then
    printf '%s\n' "${DALEK_REPO_ROOT}/.playwright/cli.config.json"
    return 0
  fi

  local dir="$PW_CALLER_CWD"
  while true; do
    if [[ -f "$dir/.playwright/cli.config.json" ]]; then
      printf '%s\n' "$dir/.playwright/cli.config.json"
      return 0
    fi
    if [[ "$dir" == "/" ]]; then
      break
    fi
    dir="$(dirname "$dir")"
  done

  if [[ -f "$HOME/.playwright/cli.config.json" ]]; then
    printf '%s\n' "$HOME/.playwright/cli.config.json"
    return 0
  fi

  return 1
}

_pw_init() {
  mkdir -p "$PW_HOME"
  _pw_find_skill
}

_pw_find_skill() {
  if [[ -d "$PW_SKILL_DIR" ]]; then
    return 0
  fi
  # seed from project skill if global seed doesn't exist yet
  local project_skill="${PW_CALLER_CWD}/.claude/skills/playwright-cli"
  if [[ -d "$project_skill" ]]; then
    mkdir -p "$PW_SKILL_DIR"
    cp -R "$project_skill"/* "$PW_SKILL_DIR"/
  fi
}

_pw_exec() {
  local config=""
  config="$(_pw_find_config)" || true
  (
    cd "$PW_HOME"
    if [[ -n "$config" ]]; then
      "$PW_BIN" "-s=$PW_SESSION" "--config=$config" "$@"
    else
      "$PW_BIN" "-s=$PW_SESSION" "$@"
    fi
  )
}

_pw_is_running() {
  _pw_exec tab-list >/dev/null 2>&1
}

if [[ $# -eq 0 ]]; then
  _pw_usage
  exit 0
fi

command="$1"
shift

case "$command" in
  help|-h|--help)
    _pw_usage
    exit 0
    ;;
  setup)
    _pw_setup
    exit 0
    ;;
  init-skill)
    if [[ ! -d "$PW_SKILL_DIR" ]]; then
      echo "[pw] skill source not found: $PW_SKILL_DIR" >&2
      exit 1
    fi
    _pw_target=".claude/skills/playwright-cli"
    mkdir -p "$_pw_target"
    cp -R "$PW_SKILL_DIR"/* "$_pw_target"/
    echo "[pw] skill installed to $_pw_target/"
    exit 0
    ;;
esac

_pw_require_cli
_pw_init

case "$command" in
  open)
    if _pw_is_running; then
      _pw_exec tab-new "$@"
    else
      _pw_exec open "$@"
    fi
    ;;
  close)
    if _pw_is_running; then
      _pw_exec tab-close "$@"
    else
      echo "Browser '$PW_SESSION' is not open." >&2
    fi
    ;;
  stop)
    _pw_exec close "$@"
    ;;
  status)
    _pw_exec list
    if _pw_is_running; then
      _pw_exec tab-list
    fi
    ;;
  *)
    _pw_exec "$command" "$@"
    ;;
esac
