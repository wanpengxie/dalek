# OpenRouter API Key（OpenAI 兼容接口用）
# 说明：这里变量名用 OPENAI_API_KEY，脚本也支持 OPENROUTER_API_KEY（二选一即可）。
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：覆盖 watcher 默认模型
# DALEK_WATCHER_MODEL=openai/gpt-oss-120b

# 可选：OpenRouter base url（一般不需要改）
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 可选：OpenRouter 归因信息（不填也能用）
# OPENROUTER_HTTP_REFERER=https://example.com
# OPENROUTER_APP_TITLE=dalek-watcher

